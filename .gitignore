# Build directories
/build/
**/build/
/build-*/
**/build-*/
/.worktrees/

# Compiled objects, libraries, and binaries
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.bin
*.cubin
*.fatbin

# Profiler and generated GPU artifacts
*.ncu-rep
*.nsys-rep
*.sass
*.ptx

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/

# Local AI agent customizations
/.github/skills/
/.github/copilot-instructions.md
/.claude/skills/

# Editor swap files
*.swp
*.swo

# Ignore ad-hoc raw runs; the reviewed canonical CSV is force-added explicitly.
/projects/gemm/results/raw/*.csv

# Generated GEMM reports
/projects/gemm/results/generated/**/*.md
/projects/gemm/results/generated/*.md

# Nsight Compute and SASS reproduction outputs
/projects/gemm/results/profiles/
/projects/gemm/results/sass/

# FlashAttention benchmark/profile reproduction outputs
/projects/flash_attention/results/raw/*.csv
/projects/flash_attention/results/generated/*.md
/projects/flash_attention/results/profiles/
/projects/flash_attention/results/sass/
